      "bin\\ZedG.exe",
      "zedg"
    ]
  ],
  "shortcuts": [
    [
      "ZedG.exe",
      "ZedG"
    ]
  ],
  "post_install": [
    "$desktop = [Environment]::GetFolderPath(\"Desktop\")",
    "$ws = New-Object -ComObject WScript.Shell",
    "$lnk = $ws.CreateShortcut(\"$desktop\\ZedG.lnk\")",
    "$lnk.TargetPath = \"$dir\\ZedG.exe\"",
    "$lnk.WorkingDirectory = \"$dir\"",
    "$lnk.Save()"
  ],
  "pre_uninstall": [
    "$desktop = [Environment]::GetFolderPath(\"Desktop\")",
    "Remove-Item \"$desktop\\ZedG.lnk\" -ErrorAction SilentlyContinue"
  ],
  "checkver": {
    "github": "https://github.com/x6nux/zed-globalization"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/x6nux/zed-globalization/releases/download/v$version/zedg-zh-cn-windows-x86_64-v$version.zip",
        "hash": {
          "url": "https://github.com/x6nux/zed-globalization/releases/download/v$version/sha256sums.txt",
          "regex": "([a-f0-9]{64})\\s+zedg-zh-cn-windows-x86_64-v\\$version\\.zip"
