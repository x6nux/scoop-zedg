  "architecture": {
    "64bit": {
      "url": "https://github.com/x6nux/zed-globalization/releases/download/v1.9.0/zedg-zh-cn-windows-x86_64-v1.9.0.zip",
      "hash": "76c83bc8406cd1ce78b4a530265e26425f1a99f5d3d85c7d3383961a50fe91bf"
    },
    "arm64": {
      "url": "https://github.com/x6nux/zed-globalization/releases/download/v1.9.0/zedg-zh-cn-windows-aarch64-v1.9.0.zip",
      "hash": "4aee4c474d8a0d9bc540ee796eedbea5511d88c4d4f66c8c345705dbac9863e1"
    }
  },
  "bin": [
    [
      "bin\\ZedG.exe",
      "zedg"
    ]
  ],
  "shortcuts": [
    [
      "ZedG.exe",
      "ZedG"
    ]
  ],
  "post_install": [
    "$desktop = [Environment]::GetFolderPath(\"Desktop\")",
    "$ws = New-Object -ComObject WScript.Shell",
    "$lnk = $ws.CreateShortcut(\"$desktop\\ZedG.lnk\")",
    "$lnk.TargetPath = \"$dir\\ZedG.exe\"",
    "$lnk.WorkingDirectory = \"$dir\"",
    "$lnk.Save()"
  ],
  "pre_uninstall": [
    "$desktop = [Environment]::GetFolderPath(\"Desktop\")",
    "Remove-Item \"$desktop\\ZedG.lnk\" -ErrorAction SilentlyContinue"
  ],
  "checkver": {
    "github": "https://github.com/x6nux/zed-globalization"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/x6nux/zed-globalization/releases/download/v$version/zedg-zh-cn-windows-x86_64-v$version.zip",
        "hash": {
          "url": "https://github.com/x6nux/zed-globalization/releases/download/v$version/sha256sums.txt",
          "regex": "([a-f0-9]{64})\\s+zedg-zh-cn-windows-x86_64-v\\$version\\.zip"
        }
      },
      "arm64": {
        "url": "https://github.com/x6nux/zed-globalization/releases/download/v$version/zedg-zh-cn-windows-aarch64-v$version.zip",
        "hash": {
          "url": "https://github.com/x6nux/zed-globalization/releases/download/v$version/sha256sums.txt",
          "regex": "([a-f0-9]{64})\\s+zedg-zh-cn-windows-aarch64-v\\$version\\.zip"
        }
      }
    }
  }
}
